<!DOCTYPE html>
<html>
<head>
    <title>Simple Web Application</title>

    <style>
        body {
            background-color: lightgreen;
            text-align: center;
            font-family: Arial, sans-serif;
            margin-top: 100px;
        }

        h1 {
            color: darkgreen;
        }

        p {
            font-size: 20px;
            color: black;
        }

        button {
            background-color: darkgreen;
            color: white;
            padding: 10px 20px;
            border: none;
            font-size: 16px;
            border-radius: 5px;
            cursor: pointer;
        }

        button:hover {
            background-color: green;
        }
    </style>
</head
