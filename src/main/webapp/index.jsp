Y4OjE0NTIwOTkwNzM1OTk0Njg="}}},"__module_operation_CometFeedStoryAttachmentMatchRenderer_attachment":{"__dr":"CometFeedStoryPhotoAttachmentStyle_styleTypeRenderer$normalization.graphql"},"__module_component_CometFeedStoryAttachmentMatchRenderer_attachment":{"__dr":"CometFeedStoryPhotoAttachmentStyle.react"}}}],"cache_id":"-9130027149706950550","matched_terms":[],"cix_screen":null,"future_of_feed_info":{"should_reverse_message_and_attachment_position":false,"should_overlay_header":false,"aspect_ratio_update":-1,"web_reshare_variant":"NORMAL"},"attached_story":null,"bumpers":null,"comet_sections":{"__typename":"CometStorySections","content":{"__typename":"CometFeedStoryDefaultContentStrategy","__isICometStorySection":"CometFeedStoryDefaultContentStrategy","is_prod_eligible":true,"story":{"feedback":{"id":"ZmVlZGJhY2s6MTQ1MjA5OTA3MzU5OTQ2OA=="},"comet_sections":{"above_message":null,"seo_llm_title":null,"info_icon":null,"attachment_overlay":null,"attached_story":null,"message":{"__typename":"CometFeedStoryDefaultMessageRenderingStrategy","__isICometStorySection":"CometFeedStoryDefaultMessageRenderingStrategy","is_prod_eligible":true,"story":{"is_text_only_story":false,"message":{"delight_ranges":[],"image_ranges":[],"inline_style_ranges":[],"aggregated_ranges":[],"ranges":[],"color_ranges":[],"text":"Registration Deadline: April 30, 2026\nLast chance to join our online courses before the summer break. The next online session will start in September, while in-person courses will continue in various locations around the world.\n\nCombined Level 1 & Level 2 Certificate in Chocolate Tasting\nAn intensive program created by the IICCT, designed to take you from the basics of chocolate tasting to a more confident, structured way of analyzing flavor.\n\nLevel 1: A friendly introduction to tasting chocolate. You\u2019ll learn how to identify and describe flavors while tasting examples of fine dark chocolate bars from different origins and craft chocolate makers. We\u2019ll explore aroma, texture, taste, and finish\u2014helping you build a solid foundation.\n\nLevel 2: A deeper dive into the world of fine chocolate. You\u2019ll discover how different chocolate makers work\u2014from small craft producers to larger-scale manufacturers\u2014and how each step in the process influences flavor. We\u2019ll also cover common cacao defects, the journey from bean to bar, and how chocolate has evolved over time.\n\nYou\u2019ll use the Institute\u2019s online chocolate profiling system to record and compare your tastings, helping you build a more objective and consistent approach.\n\nLevel 1: short multiple-choice test\nLevel 2: theory exam + a 30-minute blind tasting\n\nYou\u2019ll receive a professional tasting kit with over 34 chocolate samples. Shipping is included within the EU, UK, Switzerland, and Norway.\n\nTake your tasting skills to the next level,\nThis certification is ideal for chefs, pastry professionals, chocolate makers, and anyone looking to develop or validate their sensory skills in a practical, professional way.\n\nMaster the science of flavor. Elevate your professional profile."},"message_truncation_line_limit":2,"th_dat_spo":null,"attachments":[{"action_links":[]}],"id":""},"__module_operation_CometFeedStoryMessageMatchRenderer_story":{"__dr":"CometFeedStoryDefaultMessageRenderingStrategy_message$normalization.graphql"},"__module_component_CometFeedStoryMessageMatchRenderer_story":{"__dr":"CometFeedStoryDefaultMessageRenderingStrategy.react"}},"message_suffix":null,"message_container":{"__typename":"CometFeedStoryMessageContainerRenderingStrategy","__isICometStorySection":"CometFeedStoryMessageContainerRenderingStrategy","is_prod_eligible":true,"story":{"message":{"text":"Registration Deadline: April 30, 2026\nLast chance to join our online courses before the summer break. The next online session will start in September, while in-person courses will continue in various locations around the world.\n\nCombined Level 1 & Level 2 Certificate in Chocolate Tasting\nAn intensive program created by the IICCT, designed to take you from the basics of chocolate tasting to a more confident, structured way of analyzing flavor.\n\nLevel 1: A friendly introduction to tasting chocolate. You\u2019ll learn how to identify and describe flavors while tasting examples of fine dark chocolate bars from different origins and craft chocolate makers. We\u2019ll explore aroma, texture, taste, and finish\u2014helping you build a solid foundation.\n\nLevel 2: A deeper dive into the world of fine chocolate. You\u2019ll discover how different chocolate makers work\u2014from small craft producers to larger-scale manufacturers\u2014and how each step in the process influences flavor. We\u2019ll also cover common cacao defects, the journey from bean to bar, and how chocolate has evolved over time.\n\nYou\u2019ll use the Institute\u2019s online chocolate profiling system to record and compare your tastings, helping you build a more objective and consistent approach.\n\nLevel 1: short multiple-choice test\nLevel 2: theory exam + a 30-minute blind tasting\n\nYou\u2019ll receive a professional tasting kit with over 34 chocolate samples. Shipping is included within the EU, UK, Switzerland, and Norway.\n\nTake your tasting skills to the next level,\nThis certification is ideal for chefs, pastry professionals, chocolate makers, and anyone looking to develop or validate their sensory skills in a practical, professional way.\n\nMaster the science of flavor. Elevate your professional profile."},"referenced_sticker":null,"attachments":[{"style_list":["photo","fallback"]}],"text_format_metadata":null,"comet_sections":{"message":null},"id":""},"__module_operation_CometFeedStoryMessageContainerMatchRenderer_story":{"__dr":"CometFeedStoryMessageContainerRenderingStrategy_messageContainer$normalization.graphql"},"__module_component_CometFeedStoryMessageContainerMatchRenderer_story":{"__dr":"CometFeedStoryMessageContainerRenderingStrategy.re